@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var username = Context.Session.GetString("AdminUsername");
    var adminId = Context.Session.GetString("AdminId");

    bool isLoggedIn = !string.IsNullOrEmpty(adminId);

    string initials = "GU";

    if (!string.IsNullOrWhiteSpace(username))
    {
        var nameParts = username
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .ToArray();

        if (nameParts.Length > 0)
        {
            initials = new string(
                nameParts
                    .Select(x => x[0])
                    .Take(2)
                    .ToArray()
            ).ToUpper();
        }
    }
}

<div class="dashboard-topbar">

    <div class="d-flex justify-content-between align-items-center topbar-content flex-wrap gap-3">

        <!-- LEFT: TITLE -->
        <div class="dashboard-title">
            <h2>Dashboard</h2>
            <p>Manage contracts and logistics operations.</p>
        </div>

        <!-- CENTER: SEARCH -->
        <div class="dashboard-search flex-grow-1" style="max-width:420px;">
            <div class="input-group">
                <span class="input-group-text">
                    <i class="fa fa-search"></i>
                </span>

                <input type="text"
                       class="form-control"
                       placeholder="Search..." />
            </div>
        </div>

        <!-- RIGHT: USER INFO -->
        <div class="d-flex align-items-center gap-2 admin-section">

            <div class="admin-avatar-small">
                @initials
            </div>

            <div class="admin-info">
                @if (isLoggedIn)
                {
                    <h6>@username</h6>
                    <small>Admin</small>
                }
                else
                {
                    <h6>Guest User</h6>
                    <small>Not Signed In</small>
                }
            </div>

        </div>

    </div>
</div>

<style>
    .dashboard-topbar {
        background: #fff;
        padding: 12px 18px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }

    .dashboard-title h2 {
        font-size: 20px;
        font-weight: 600;
        margin: 0;
        color: #1e293b;
    }

    .dashboard-title p {
        margin: 2px 0 0;
        color: #64748b;
        font-size: 12px;
    }

    .dashboard-search .input-group-text {
        background: #f8fafc;
        border-right: none;
        padding: 0 14px;
    }

    .dashboard-search .form-control {
        background: #f8fafc;
        border-left: none;
        height: 38px;
        font-size: 13px;
    }

        .dashboard-search .form-control:focus {
            box-shadow: none;
        }

    .admin-avatar-small {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        background: linear-gradient(135deg,#0f172a,#2563eb);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
        font-size: 13px;
    }

    .admin-info h6 {
        margin: 0;
        font-size: 13px;
        font-weight: 600;
        color: #1e293b;
    }

    .admin-info small {
        color: #64748b;
        font-size: 11px;
    }

    @@media(max-width:768px) {
        .topbar-content {
            flex-direction: column;
            align-items: stretch !important;
        }

        .admin-section {
            justify-content: space-between;
        }
    }
</style>