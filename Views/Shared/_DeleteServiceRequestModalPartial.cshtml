<div class="modal fade" id="deleteServiceRequestModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title fw-bold text-danger">Delete Service Request</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form asp-controller="ServiceRequest" asp-action="DeleteServiceRequest" method="post">
                <div class="modal-body">
                    <input type="hidden" name="id" id="deleteServiceRequestId" />

                    <p class="mb-1">Are you sure you want to delete this service request?</p>
                    <strong id="deleteServiceRequestName"></strong>

                    <div class="alert alert-warning mt-3 mb-0">
                        This action cannot be undone.
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete Request</button>
                </div>
            </form>

        </div>
    </div>
</div>