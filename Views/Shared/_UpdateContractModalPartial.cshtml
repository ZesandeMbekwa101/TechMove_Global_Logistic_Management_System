<div class="modal fade" id="updateContractModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">

            <div class="modal-header">
                <div>
                    <h5 class="modal-title fw-bold">Update Contract</h5>
                    <small class="text-muted">Edit contract and optionally replace PDF</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form asp-controller="Contract" asp-action="UpdateContract" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                    <div class="row g-3">

                        <input type="hidden" name="Contract_Id" id="editContractId" />
                        <input type="hidden" name="Admin_Id" value="1" />

                        <div class="col-md-6">
                            <label class="form-label">Client ID</label>
                            <input name="Client_Id" id="editContractClientId" type="number" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Service Level</label>
                            <select name="Service_Level" id="editServiceLevel" class="form-select" required>
                                <option>Standard</option>
                                <option>Silver</option>
                                <option>Gold</option>
                                <option>Platinum</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Start Date</label>
                            <input name="Start_Date" id="editStartDate" type="date" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">End Date</label>
                            <input name="End_Date" id="editEndDate" type="date" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Status</label>
                            <select name="Status" id="editStatus" class="form-select" required>
                                <option>Draft</option>
                                <option>Active</option>
                                <option>On Hold</option>
                                <option>Expired</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Replace Signed PDF</label>
                            <input name="pdfFile" type="file" accept="application/pdf" class="form-control" />
                        </div>

                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Contract</button>
                </div>
            </form>

        </div>
    </div>
</div>