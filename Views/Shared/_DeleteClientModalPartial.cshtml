@model TechMove_Global_Logistic_Management_System.Models.ClientModel

@{
    Layout = null;
}
<div class="modal fade" id="deleteClientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title fw-bold text-danger">Delete Client</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <form asp-controller="Client" asp-action="DeleteClient" method="post">
                <div class="modal-body">
                    <input type="hidden" name="id" id="deleteClientId" />

                    <p class="mb-1">Are you sure you want to delete this client?</p>
                    <strong id="deleteClientName"></strong>

                    <div class="alert alert-warning mt-3 mb-0">
                        This action cannot be undone.
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Delete Client</button>
                </div>
            </form>

        </div>
    </div>
</div>