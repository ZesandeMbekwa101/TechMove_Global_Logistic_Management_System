<div class="modal fade" id="updateClientModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">
                    Update Client
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <form asp-controller="Client"
                  asp-action="UpdateClient"
                  method="post">

                <div class="modal-body">

                    <input type="hidden"
                           name="Client_Id"
                           id="editClientId" />

                    <div class="row">

                        <div class="col-md-6 mb-3">
                            <label>Client Name</label>

                            <input name="Client_Name"
                                   id="editClientName"
                                   class="form-control"
                                   required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Contact Person</label>

                            <input name="Contact_Person"
                                   id="editContactPerson"
                                   class="form-control"
                                   required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Phone Number</label>

                            <input name="Phone_Number"
                                   id="editPhoneNumber"
                                   class="form-control"
                                   required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Email Address</label>

                            <input name="Email_Address"
                                   id="editEmailAddress"
                                   class="form-control"
                                   required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Region</label>

                            <input name="Region"
                                   id="editRegion"
                                   class="form-control"
                                   required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label>Country</label>

                            <input name="Country"
                                   id="editCountry"
                                   class="form-control"
                                   required />
                        </div>

                    </div>

                </div>

                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Cancel
                    </button>

                    <button type="submit"
                            class="btn btn-primary">
                        Update Client
                    </button>

                </div>

            </form>

        </div>
    </div>
</div>